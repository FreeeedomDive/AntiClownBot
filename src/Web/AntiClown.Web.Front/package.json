{
  "name": "front",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@chakra-ui/react": "^3.13.0",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^5.15.11",
    "@mui/lab": "^5.0.0-alpha.166",
    "@mui/material": "^5.15.2",
    "@mui/x-charts": "^7.11.1",
    "@types/node": "^20.19.0",
    "@types/react": "^18.2.24",
    "@types/react-dom": "^18.2.9",
    "@types/telegram-web-app": "^7.10.1",
    "axios": "^1.6.3",
    "localforage": "^1.10.0",
    "match-sorter": "^6.3.1",
    "mobx": "^6.12.0",
    "mobx-react-lite": "^4.0.5",
    "react": "^18.2.0",
    "react-cookie": "^6.1.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-document-title": "^2.0.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "sort-by": "^1.2.0"
  },
  "scripts": {
    "ensure-tg-sdk": "node -e \"const fs=require('fs');const p='public/telegram-web-app.js';if(!fs.existsSync(p)){fs.copyFileSync('vendor/telegram-web-app.js',p);console.log('[ensure-tg-sdk] copied fallback from vendor/telegram-web-app.js');}\"",
    "prestart": "npm run ensure-tg-sdk",
    "prebuild": "npm run ensure-tg-sdk",
    "start": "vite --port 3000",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@types/react-document-title": "^2.0.10",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "3.1.1",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "typescript": "~6.0.2"
  }
}
